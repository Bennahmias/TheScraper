<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ADL Regional Instagram Action Analysis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      :root {
        color-scheme: light;
        --ink: #08214a;
        --muted: #5b6b82;
        --line: #d9e0ea;
        --teal: #078d99;
        --blue: #0b5cad;
        --amber: #e49a00;
        --surface: #ffffff;
      }

      body {
        background: #ffffff;
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      .focus-ring:focus {
        outline: 2px solid var(--teal);
        outline-offset: 2px;
      }

      .chart-shell {
        height: 300px;
      }

      @media (max-width: 900px) {
        .chart-shell {
          height: 240px;
        }
      }
    </style>
  </head>
  <body>
    <header class="border-b border-slate-200 bg-white">
      <div class="flex flex-col gap-4 px-5 py-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-center gap-4">
          <div class="text-3xl font-black tracking-normal text-[#0b5cad]">ADL</div>
          <div>
            <h1 class="text-xl font-semibold leading-tight text-[#08214a] md:text-2xl">
              ADL Regional Instagram Action Analysis
            </h1>
            <p class="text-sm text-slate-500">Posts from {{ since }}. Generated {{ generated_at }}.</p>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button
            id="exportJson"
            class="focus-ring rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-[#08214a] hover:border-[#078d99]"
          >
            Export JSON
          </button>
          <button
            id="printReport"
            class="focus-ring rounded-md bg-[#08214a] px-3 py-2 text-sm font-medium text-white hover:bg-[#0b5cad]"
          >
            Print / PDF
          </button>
        </div>
      </div>
    </header>

    <main class="grid min-h-screen grid-cols-1 lg:grid-cols-[280px_1fr]">
      <aside class="border-b border-slate-200 bg-white p-5 lg:border-b-0 lg:border-r">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="text-xs font-bold uppercase tracking-normal text-[#08214a]">Filters</h2>
          <button id="clearFilters" class="text-xs font-medium text-[#0b5cad]">Clear</button>
        </div>

        <label class="mb-2 block text-sm font-semibold text-[#08214a]" for="searchInput">Search</label>
        <input
          id="searchInput"
          class="focus-ring mb-5 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"
          placeholder="Caption, strategy, account"
        />

        <label class="mb-2 block text-sm font-semibold text-[#08214a]" for="accountFilter">Account</label>
        <select id="accountFilter" class="focus-ring mb-5 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
          <option value="">All accounts</option>
        </select>

        <label class="mb-2 block text-sm font-semibold text-[#08214a]" for="categoryFilter">Category</label>
        <select id="categoryFilter" class="focus-ring mb-5 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
          <option value="">All categories</option>
        </select>

        <label class="mb-2 block text-sm font-semibold text-[#08214a]" for="toneFilter">Tone</label>
        <select id="toneFilter" class="focus-ring mb-5 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
          <option value="">All tones</option>
        </select>

        <label class="flex items-center gap-2 text-sm text-slate-700">
          <input id="equippedFilter" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-[#078d99]" />
          Equipped followers only
        </label>
      </aside>

      <section class="overflow-hidden">
        <div class="grid grid-cols-2 border-b border-slate-200 bg-white md:grid-cols-5">
          <div class="border-r border-slate-200 p-5">
            <div class="text-sm font-medium text-slate-500">Total Posts</div>
            <div id="kpiPosts" class="mt-1 text-3xl font-semibold">{{ total_posts }}</div>
          </div>
          <div class="border-r border-slate-200 p-5">
            <div class="text-sm font-medium text-slate-500">Accounts</div>
            <div class="mt-1 text-3xl font-semibold">{{ account_count }}</div>
          </div>
          <div class="border-r border-slate-200 p-5">
            <div class="text-sm font-medium text-slate-500">Equipping Posts</div>
            <div id="kpiEquipped" class="mt-1 text-3xl font-semibold">{{ equipped_count }}</div>
          </div>
          <div class="border-r border-slate-200 p-5">
            <div class="text-sm font-medium text-slate-500">Avg. Actionability</div>
            <div id="kpiActionability" class="mt-1 text-3xl font-semibold">{{ avg_actionability }}</div>
          </div>
          <div class="p-5">
            <div class="text-sm font-medium text-slate-500">Engagement</div>
            <div id="kpiEngagement" class="mt-1 text-3xl font-semibold">{{ total_engagement }}</div>
          </div>
        </div>

        {% if warnings %}
        <div class="border-b border-amber-200 bg-amber-50 px-5 py-3 text-sm text-amber-900">
          {% for warning in warnings %}
          <div>{{ warning }}</div>
          {% endfor %}
        </div>
        {% endif %}

        <div class="grid grid-cols-1 border-b border-slate-200 xl:grid-cols-2">
          <section class="border-b border-slate-200 p-5 xl:border-b-0 xl:border-r">
            <h2 class="mb-4 text-base font-semibold">Posts by Category</h2>
            <div class="chart-shell">
              <canvas id="categoryChart"></canvas>
            </div>
          </section>
          <section class="p-5">
            <h2 class="mb-4 text-base font-semibold">Posts Over Time</h2>
            <div class="chart-shell">
              <canvas id="timelineChart"></canvas>
            </div>
          </section>
        </div>

        <section class="border-b border-slate-200 p-5">
          <h2 class="mb-4 text-base font-semibold">Account Performance Comparison</h2>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[860px] border-collapse text-sm">
              <thead>
                <tr class="border-y border-slate-200 bg-slate-50 text-left text-xs uppercase text-slate-500">
                  <th class="px-3 py-2">Account</th>
                  <th class="px-3 py-2 text-right">Posts</th>
                  <th class="px-3 py-2 text-right">Engagement</th>
                  <th class="px-3 py-2 text-right">Equipped</th>
                  <th class="px-3 py-2 text-right">Avg. Actionability</th>
                  <th class="px-3 py-2">Top Category</th>
                  <th class="px-3 py-2">Top Tone</th>
                </tr>
              </thead>
              <tbody id="accountTable">
                {% for row in account_rows %}
                <tr class="border-b border-slate-100">
                  <td class="px-3 py-2 font-medium">{{ row.account }}</td>
                  <td class="px-3 py-2 text-right">{{ row.posts }}</td>
                  <td class="px-3 py-2 text-right">{{ row.engagement }}</td>
                  <td class="px-3 py-2 text-right">{{ row.equipped }}</td>
                  <td class="px-3 py-2 text-right">{{ row.avg_actionability }}</td>
                  <td class="px-3 py-2">{{ row.top_category }}</td>
                  <td class="px-3 py-2">{{ row.top_tone }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="p-5">
          <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div>
              <h2 class="text-base font-semibold">Media Evidence</h2>
              <p id="resultCount" class="mt-1 text-sm text-slate-500"></p>
            </div>
          </div>
          <div id="postGrid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4"></div>
        </section>
      </section>
    </main>

    <script>
      const posts = {{ posts_json | safe }};
      const categories = {{ categories_json | safe }};
      const tones = {{ tones_json | safe }};
      const timeline = {{ timeline_json | safe }};

      const state = {
        search: "",
        account: "",
        category: "",
        tone: "",
        equipped: false,
      };

      const palette = ["#078d99", "#0b5cad", "#e49a00", "#4f6f8f", "#1f9d75", "#d96c2c", "#64748b"];

      function initSelect(id, values) {
        const select = document.getElementById(id);
        values.sort().forEach((value) => {
          const option = document.createElement("option");
          option.value = value;
          option.textContent = value;
          select.appendChild(option);
        });
      }

      initSelect("accountFilter", [...new Set(posts.map((post) => post.account))]);
      initSelect("categoryFilter", [...new Set(posts.map((post) => post.category))]);
      initSelect("toneFilter", [...new Set(posts.map((post) => post.tone))]);

      const categoryChart = new Chart(document.getElementById("categoryChart"), {
        type: "bar",
        data: {
          labels: Object.keys(categories),
          datasets: [{ label: "Posts", data: Object.values(categories), backgroundColor: "#078d99" }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          indexAxis: "y",
          plugins: { legend: { display: false } },
          scales: { x: { grid: { color: "#eef2f7" } }, y: { grid: { display: false } } },
        },
      });

      const timelineChart = new Chart(document.getElementById("timelineChart"), {
        type: "line",
        data: {
          labels: timeline.map((item) => item.date),
          datasets: [
            {
              label: "Posts",
              data: timeline.map((item) => item.posts),
              borderColor: "#078d99",
              backgroundColor: "rgba(7, 141, 153, 0.12)",
              tension: 0.3,
            },
            {
              label: "Engagement",
              data: timeline.map((item) => item.engagement),
              borderColor: "#e49a00",
              backgroundColor: "rgba(228, 154, 0, 0.12)",
              tension: 0.3,
              yAxisID: "engagement",
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          scales: {
            y: { grid: { color: "#eef2f7" } },
            engagement: { position: "right", grid: { drawOnChartArea: false } },
          },
        },
      });

      function filteredPosts() {
        const query = state.search.trim().toLowerCase();
        return posts.filter((post) => {
          const haystack = [post.account, post.caption, post.strategy, post.evidence].join(" ").toLowerCase();
          return (
            (!query || haystack.includes(query)) &&
            (!state.account || post.account === state.account) &&
            (!state.category || post.category === state.category) &&
            (!state.tone || post.tone === state.tone) &&
            (!state.equipped || post.equipsFollowers)
          );
        });
      }

      function render() {
        const visible = filteredPosts();
        const grid = document.getElementById("postGrid");
        grid.innerHTML = "";
        document.getElementById("resultCount").textContent = `${visible.length} matching posts`;
        document.getElementById("kpiPosts").textContent = visible.length;
        document.getElementById("kpiEquipped").textContent = visible.filter((post) => post.equipsFollowers).length;
        document.getElementById("kpiEngagement").textContent = visible
          .reduce((sum, post) => sum + post.engagement, 0)
          .toLocaleString();
        const analyzed = visible.filter((post) => post.actionability);
        document.getElementById("kpiActionability").textContent = analyzed.length
          ? (analyzed.reduce((sum, post) => sum + post.actionability, 0) / analyzed.length).toFixed(2)
          : "0";

        visible.forEach((post, index) => {
          const image = post.screenshot || post.media || "";
          const article = document.createElement("article");
          article.className = "overflow-hidden rounded-md border border-slate-200 bg-white";
          article.innerHTML = `
            <div class="flex items-center justify-between border-b border-slate-100 px-3 py-2">
              <div>
                <div class="text-sm font-semibold text-[#08214a]">${escapeHtml(post.account)}</div>
                <div class="text-xs text-slate-500">${escapeHtml(post.date)} · ${escapeHtml(post.category)}</div>
              </div>
              <a class="text-xs font-medium text-[#0b5cad]" href="${post.postUrl}" target="_blank" rel="noreferrer">Open</a>
            </div>
            ${
              image
                ? `<img class="h-64 w-full object-cover" src="${image}" alt="Screenshot from ${escapeHtml(post.account)} post" />`
                : `<div class="flex h-64 items-center justify-center bg-slate-50 text-sm text-slate-500">No media captured</div>`
            }
            <div class="space-y-3 p-3">
              <div class="flex flex-wrap gap-2 text-xs">
                <span class="rounded bg-[#078d99]/10 px-2 py-1 font-medium text-[#087985]">${escapeHtml(post.tone)}</span>
                <span class="rounded bg-slate-100 px-2 py-1 text-slate-700">Actionability ${post.actionability}/5</span>
                ${
                  post.equipsFollowers
                    ? `<span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700">Equips followers</span>`
                    : `<span class="rounded bg-slate-100 px-2 py-1 text-slate-600">Low direct action</span>`
                }
              </div>
              <p class="line-clamp-4 text-sm leading-6 text-slate-700">${escapeHtml(post.caption || "No caption captured.")}</p>
              <div class="border-t border-slate-100 pt-3">
                <div class="text-xs font-bold uppercase text-slate-500">Strategy</div>
                <p class="mt-1 text-sm text-[#08214a]">${escapeHtml(post.strategy || "No strategy identified.")}</p>
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs text-slate-500">
                <div>Likes: ${post.likes ?? "n/a"}</div>
                <div>Comments: ${post.comments ?? "n/a"}</div>
              </div>
            </div>
          `;
          article.style.borderTopColor = palette[index % palette.length];
          grid.appendChild(article);
        });
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      document.getElementById("searchInput").addEventListener("input", (event) => {
        state.search = event.target.value;
        render();
      });
      document.getElementById("accountFilter").addEventListener("change", (event) => {
        state.account = event.target.value;
        render();
      });
      document.getElementById("categoryFilter").addEventListener("change", (event) => {
        state.category = event.target.value;
        render();
      });
      document.getElementById("toneFilter").addEventListener("change", (event) => {
        state.tone = event.target.value;
        render();
      });
      document.getElementById("equippedFilter").addEventListener("change", (event) => {
        state.equipped = event.target.checked;
        render();
      });
      document.getElementById("clearFilters").addEventListener("click", () => {
        state.search = "";
        state.account = "";
        state.category = "";
        state.tone = "";
        state.equipped = false;
        document.getElementById("searchInput").value = "";
        document.getElementById("accountFilter").value = "";
        document.getElementById("categoryFilter").value = "";
        document.getElementById("toneFilter").value = "";
        document.getElementById("equippedFilter").checked = false;
        render();
      });
      document.getElementById("printReport").addEventListener("click", () => window.print());
      document.getElementById("exportJson").addEventListener("click", () => {
        const blob = new Blob([JSON.stringify(filteredPosts(), null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = "adl-instagram-analysis.json";
        link.click();
        URL.revokeObjectURL(url);
      });

      render();
    </script>
  </body>
</html>
